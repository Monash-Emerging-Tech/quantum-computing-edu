{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Monash-Emerging-Tech/quantum-computing-edu/refs/heads/main/schemas/quantum-gate-schema.json",
  "title": "Quantum Gate",
  "type": "object",
  "oneOf": [
    { "required": ["gate_id", "full_name", "display_name", "arity", "unitary"] },
    { "required": ["gate_id", "full_name", "display_name", "arity", "subcircuit"] },
    { "required": ["gate_id", "full_name", "display_name", "arity", "subcircuit_id"] }
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "1.0"
    },
    
    "gate_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique gate identifier"
    },
    
    "full_name": {
      "type": "string",
      "description": "Name of the gate"
    },
    
    "display_name": {
      "type": "string",
      "description": "Symbols to display on the gate in the interactive view"
    },
    
    "color": {
      "type": "string",
      "description": "Color of the gate in the interactive view"
    },
    
    "arity": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of qubits that this gate acts upon. It must agree with the unitary or subcircuit definition."
    },
    
    "unitary": {
      "description": "Unitary matrix representation",
      "$ref": "#/$defs/unitaryMatrix"
    },
    
    "subcircuit": {
      "description": "Circuit representation",
      "$ref": "https://raw.githubusercontent.com/Monash-Emerging-Tech/quantum-computing-edu/refs/heads/main/schemas/quantum-circuit-schema.json"
    },
    
    "subcircuit_id": {
      "type": "string",
      "minLength": 1,
      "description": "The ID of the circuit that defines this gate"
    },
    
    "documentation_file": {
      "type": "string",
      "description": "File path of the accompanying documentation"
    }
  },
  
  "$defs": {
    "math_expr": {
      "type": "string",
      "minLength": 1,
      "description": "Mathematical expression that can be parsed by MathJS. See https://mathjs.org/docs/expressions/syntax.html."
    },
    
    "unitaryMatrix": {
      "type": "array",
      "items": {
        "type": "array",
        "items": {
          "oneOf": [
            { "type": "number" },
            { "$ref": "#/$defs/math_expr" }
          ]
        }
      },
      "description": "Unitary matrix in row-major format"
    }
  }
}
