{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Monash-Emerging-Tech/quantum-computing-edu/refs/heads/main/schemas/quantum-circuit-schema.json",
  "title": "Quantum Circuit",
  "type": "object",
  "required": ["circuit_id", "name", "registers", "operations"],
  "properties": {
    "schema_version": {
      "type": "string",
      "default": "1.0"
    },
    
    "circuit_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique circuit identifier"
    },
    
    "full_name": {
      "type": "string",
      "description": "Name of the circuit"
    },
    
    "display_name": {
      "type": "string",
      "description": "Short name for the circuit"
    },
    
    "registers": {
      "type": "array",
      "items": { "$ref": "#/$defs/register" }
    },
    
    "operations": {
      "type": "array",
      "items": { "$ref": "#/$defs/operation" }
    },
    
    "documentation_file": {
      "type": "string"
    }
  },
  
  "$defs": {
    "qubit": {
      "type": "integer",
      "minimum": 0
    },
    
    "operation": {
      "type": "object",
      "oneOf": [
        { "required": ["gate_id", "qubits"] },
        { "required": ["custom_gate", "qubits"] }
      ],
      "properties": {
        "gate_id": {
          "type": "string",
          "minLength": 1,
          "description": "The ID of the gate that makes up this operation"
        },
        
        "custom_gate": {
          "description": "Definition of a custom gate",
          "$ref": "https://raw.githubusercontent.com/Monash-Emerging-Tech/quantum-computing-edu/refs/heads/main/schemas/quantum-gate-schema.json"
        },
        
        "qubits": {
          "type": "array",
          "description": "Qubits operated upon by this gate (in the correct order to match the gate)",
          "items": { "$ref": "#/$defs/qubit" },
          "uniqueItems": true,
          "minItems": 1
        },
        
        "controls": {
          "type": "array",
          "description": "Control qubits",
          "items": { "$ref": "#/$defs/qubit" },
          "uniqueItems": true,
          "minItems": 1,
          "default": []
        },
        
        "anticontrols": {
          "type": "array",
          "description": "Anti-control qubits",
          "items": { "$ref": "#/$defs/qubit" },
          "uniqueItems": true,
          "minItems": 1,
          "default": []
        },
        
        "inverse": {
          "type": "boolean",
          "description": "Whether the gate is inverted"
        },
        
        "exponent": {
          "type": "integer",
          "minimum": 1,
          "description": "Optional exponent to raise the gate to, for repeated application of the gate"
        },
        
        "parameter_values": {
          "type": "array",
          "items": { "$ref": "#/$defs/parameterValue" }
        }
      }
    },
    
    "register": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        
        "description": { "type": "string" },
        
        "qubits": {
          "type": "array",
          "description": "Qubits included in this register",
          "items": { "$ref": "#/$defs/qubit" },
          "uniqueItems": true,
          "minItems": 1
        }
      }
    },
    
    "parameterValue": {
      "type": "object",
      "required": ["symbol", "value"],
      "properties": {
        "symbol": {
          "type": "string",
          "minLength": 1,
          "description": "The symbol representing the parameter in the gate definition"
        },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" }
          ],
          "description": "Value that this parameter is set to (can itself be a symbol)"
        }
      },
      "description": "Value of a numeric parameter used in the definition of a gate"
    }
  }
}
